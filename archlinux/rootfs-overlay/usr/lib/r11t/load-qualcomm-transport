#!/bin/sh
set -eu

mkdir -p /dev/disk/by-partlabel /run/r11t
for block in /sys/class/block/mmcblk*p*; do
	[ -r "$block/uevent" ] || continue
	name=$(sed -n 's/^PARTNAME=//p' "$block/uevent")
	[ -n "$name" ] || continue
	ln -sfn "/dev/${block##*/}" "/dev/disk/by-partlabel/$name"
done
for alias in oem_stanvbk:oppostanvbk oem_dycnvbk:oppodycnvbk; do
	dest=${alias%%:*}
	source=${alias##*:}
	[ -e "/dev/disk/by-partlabel/$source" ] || continue
	ln -sfn "$(readlink -f "/dev/disk/by-partlabel/$source")" \
		"/dev/disk/by-partlabel/$dest"
done

for module in \
	rmtfs_mem libarc4 rfkill cfg80211 mac80211 ath qmi_helpers \
	qrtr qrtr-smd qcom_pdr_msg pdr_interface qcom-r11t-memshare \
	qcom_pd_mapper mdt_loader qcom_pil_info qcom_common qcom_aoss \
	qcom_sysmon ipa2-lite qcom_q6v5 qcom_q6v5_mss; do
	modprobe "$module"
done

for retry in $(seq 1 100); do
	[ -e /dev/qcom_rmtfs_mem1 ] && exit 0
	sleep 0.1
done
echo 'RMTFS shared-memory device did not register' >&2
exit 1
