#!/bin/busybox sh
set -eu

/bin/busybox --install -s /bin
mkdir -p /tmp
mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t configfs configfs /sys/kernel/config
hostname r11t-installer

resolve_part() {
	name=$1
	for retry in $(seq 1 100); do
		for b in /sys/class/block/mmcblk*p*; do
			[ -r "$b/uevent" ] || continue
			partname=$(sed -n 's/^PARTNAME=//p' "$b/uevent")
			[ "$partname" = "$name" ] || continue
			printf '/dev/%s\n' "${b##*/}"
			return 0
		done
		sleep 0.1
	done
	return 1
}

TARGET=system
case " $(cat /proc/cmdline) " in
	*' r11t.install_target=userdata '*) TARGET=userdata ;;
	*' r11t.install_target=system '*) TARGET=system ;;
	*' r11t.install_target=all '*) TARGET=all ;;
esac

g=/sys/kernel/config/usb_gadget/r11t-installer
mkdir -p "$g/strings/0x409" "$g/configs/c.1/strings/0x409"
echo 0x18d1 > "$g/idVendor"
echo 0xd002 > "$g/idProduct"
echo r11t-installer > "$g/strings/0x409/serialnumber"
echo OPPO > "$g/strings/0x409/manufacturer"
echo "R11T Arch installer (ECM)" > "$g/strings/0x409/product"
echo 'ACM + ECM installer network' > "$g/configs/c.1/strings/0x409/configuration"

mkdir -p "$g/functions/acm.usb0"
ln -s "$g/functions/acm.usb0" "$g/configs/c.1/acm.usb0"

mkdir -p "$g/functions/ecm.usb0"
echo 02:60:66:00:00:01 > "$g/functions/ecm.usb0/dev_addr"
echo 02:60:66:00:00:02 > "$g/functions/ecm.usb0/host_addr"
ln -s "$g/functions/ecm.usb0" "$g/configs/c.1/ecm.usb0"

set -- /sys/class/udc/*
[ -e "$1" ] || { echo 'No UDC found' >&2; exit 1; }
echo "${1##*/}" > "$g/UDC"

while [ ! -e /dev/ttyGS0 ]; do sleep 1; done
for retry in $(seq 1 100); do
	[ -d /sys/class/net/usb0 ] && break
	sleep 0.1
done
[ -d /sys/class/net/usb0 ] || { echo 'ECM usb0 did not register' >&2; exit 1; }
ifconfig usb0 172.31.66.1 netmask 255.255.255.0 up
stty -F /dev/ttyGS0 raw -echo
exec </dev/ttyGS0 >/dev/ttyGS0 2>&1

echo 'OPPO R11T Arch installer recovery'
echo 'ECM address: 172.31.66.1/24'
echo "Selected install target: $TARGET"
case " $(cat /proc/cmdline) " in
	*' r11t.storage_write=1 '*)
		 echo 'Image receiver is enabled; no write starts automatically.'
		echo 'Run receive_arch_image or receive_arch_boot with explicit size, hash, and --confirm.'
		;;
	*) echo 'Network test mode: block-device writes are disabled.' ;;
esac

cat > /bin/restore_bootbak << 'EOF'
#!/bin/busybox sh
set -eu
[ "${1:-}" = --confirm ] || {
	echo 'usage: restore_bootbak --confirm' >&2
	exit 2
}

resolve() {
	name=$1
	for block in /sys/class/block/mmcblk*p*; do
		[ -r "$block/uevent" ] || continue
		[ "$(sed -n 's/^PARTNAME=//p' "$block/uevent")" = "$name" ] || continue
		echo "/dev/${block##*/}"
		return 0
	done
	return 1
}

boot=$(resolve boot)
bootbak=$(resolve bootbak)
for dev in "$boot" "$bootbak"; do
	sectors=$(cat "/sys/class/block/${dev##*/}/size")
	[ "$sectors" = 131072 ] || {
		echo "unexpected size for $dev: $sectors sectors" >&2
		exit 1
	}
done

source_hash=$(sha256sum "$bootbak" | cut -d' ' -f1)
dd if="$bootbak" of="$boot" bs=4096 count=16384 conv=fsync status=none
target_hash=$(sha256sum "$boot" | cut -d' ' -f1)
[ "$source_hash" = "$target_hash" ] || {
	echo 'bootbak restore verification failed' >&2
	exit 1
}
echo "boot restored from bootbak: $target_hash"
EOF
chmod 0755 /bin/restore_bootbak
echo 'Boot rollback: restore_bootbak --confirm'
exec setsid sh -c 'exec sh < /dev/ttyGS0 > /dev/ttyGS0 2>&1'
